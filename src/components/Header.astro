---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove the first "/"
import Text from "../components/Text.astro";
import Heading from "../components/Heading.astro";
import Link from "./Link.astro";
---

<nav class="fixed top-0 left-0 w-full bg-base-100 z-50">
  <!-- øverste bar med info -->
  <div class="bg-[var(--color-surfacedarker)] grid grid-cols-2 text-center text-[12px] lg:text-[14px] py-2">
    <div class="flex items-center justify-center gap-1 lg:gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" class="size-6 stroke-current text-primary-content" role="img" aria-label="Gratis levering">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"
        ></path>
      </svg>

      <Text teksttype="body" color="negative">Gratis levering ved køb over 500 kr.</Text>
    </div>

    <div class="flex items-center justify-center gap-1 lg:gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" class="size-6 stroke-current text-primary-content" role="img" aria-label="Levering inden 1-3 hverdage">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"
        ></path>
      </svg>
      <Text teksttype="body" color="negative">Leveres inden for 1-3 hverdage</Text>
    </div>
  </div>

  <div class="navbar px-4 lg:px-8 py-4">
    <!-- LEFT -->
    <div class="flex items-center">
      <a href="/">
        <img src="/img/logo/LogoBlue.png" alt="Crying Wine" class="h-10 lg:h-16 w-auto" />
      </a>
    </div>

    <!-- DESKTOP MENU -->
    <div class="hidden lg:flex">
      <ul class="menu menu-horizontal gap-2">
        <li>
          <Link variant="textlinkBlack" href="/paahylden"> På hylden </Link>
        </li>

        <li>
          <Link variant="textlinkBlack" href="/bagomcrying"> Bag om crying </Link>
        </li>

        <li>
          <Link variant="textlinkBlack" href="/flaskentilmaden"> Flasken til maden </Link>
        </li>
      </ul>
    </div>

    <!-- RIGHT -->
    <div class="ml-auto flex items-center gap-(--gapweb-xs)">
      <!-- SEARCH (desktop only) -->
      <div class="hidden lg:flex items-center border-b border-(var(--color-surfacedarker))">
        <input type="text" placeholder="Søg" class="bg-transparent border-none outline-none placeholder:text-(var(--color-surfacedarker)) w-60 p-0" />
      </div>

      <!-- ACCOUNT ICON -->
      <a href="/konto" class="hidden lg:flex">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" role="img" aria-label="Min konto" class="text-(var(--color-surfacedarker))">
          <path d="M20 21a8 8 0 1 0-16 0"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </a>

      <!-- CART -->
      <a href="/" class="relative inline-flex items-start justify-center">
        <!-- Sæt dit eget billede ind her -->
        <img src="/img/illustrations/putikassendark.png" alt="Kurv" class="w-7 h-7" />
        <span id="cart-count-badge" class="hidden absolute -top-2 -right-2 min-w-5 h-5 px-1 rounded-full bg-primary text-primary-content text-[10px] font-bold leading-5 text-center"> 0 </span>
      </a>

      <!-- MOBILE MENU -->
      <div class="lg:hidden relative z-50">
        <!-- hidden checkbox -->
        <input id="mobile-menu" type="checkbox" class="peer hidden" />

        <!-- BUTTON -->
        <label for="mobile-menu" class="cursor-pointer relative z-50 block">
          <!-- hamburger -->
          <svg class="peer-checked:hidden text-[var(--color-surfacedarker)]" xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 512 512" fill="currentColor" role="img" aria-label="Åbn menu">
            <path d="M64,384H448V341.33H64Zm0-106.67H448V234.67H64ZM64,128v42.67H448V128Z"></path>
          </svg>

          <!-- close -->
          <svg class="hidden peer-checked:block text-primary-content" xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 512 512" fill="currentColor" role="img" aria-label="Luk menu">
            <polygon points="400 145.49 366.51 112 256 222.51 145.49 112 112 145.49 222.51 256 112 366.51 145.49 400 256 289.49 366.51 400 400 366.51 289.49 256 400 145.49"></polygon>
          </svg>
        </label>

        <!-- OVERLAY -->
        <div class="fixed top-0 right-0 h-screen w-2/3 bg-primary text-primary-content translate-x-full peer-checked:translate-x-0 transition-transform duration-300 ease-in-out z-40 flex flex-col px-8 pt-28">
          <!-- menu -->
          <ul class="flex flex-col gap-8 text-2xl font-semibold text-(var(--color-surfacedarker)) items-end">
            <li>
              <Link size="large" href="/paahylden">På hylden</Link>
            </li>

            <li>
              <Link size="large" href="/bagomcrying">Bag om crying</Link>
            </li>

            <li>
              <Link size="large" href="/flaskentilmaden">Flasken til maden</Link>
            </li>
            <li>
              <Link size="large" href="/login">Login</Link>
            </li>
          </ul>

          <!-- bottom section -->
          <div class="mt-12 flex flex-col">
            <!-- search -->
            <div class="border-b border-primary-content">
              <input type="text" placeholder="Søg" class="bg-transparent border-none outline-none placeholder:text-primary-content w-full text-right p-0 m-0" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (() => {
      const badge = document.getElementById("cart-count-badge");
      if (!badge) return;

      let count = 0;

      const updateBadge = () => {
        badge.textContent = String(count);
        badge.classList.toggle("hidden", count === 0);
      };

      updateBadge();

      window.addEventListener("cartAdded", (event) => {
        const increment = Number(event?.detail?.quantity ?? 1) || 1;
        count += increment;
        updateBadge();
      });
    })();
  </script>
</nav>
