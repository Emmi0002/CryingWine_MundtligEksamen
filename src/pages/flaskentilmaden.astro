---
import MainLayout from "../layouts/MainLayout.astro";
import Heading from "../components/Heading.astro";
import ProductCard from "../components/ProductCard.astro";
import Button from "../components/Button.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import TasteBox from "../components/TasteBox.astro";
import Link from "../components/Link.astro";

const SUPABASE_URL = "https://lbkrfecnofyqzkuhuins.supabase.co";

const SUPABASE_KEY = "sb_publishable_y5b_SwFaDlD8jvcpEA-GiQ_nP-3VCkg";

const response = await fetch(`${SUPABASE_URL}/rest/v1/CryingWine?select=*`, {
  method: "GET",
  headers: {
    apikey: SUPABASE_KEY,
    Authorization: `Bearer ${SUPABASE_KEY}`,
    "Content-Type": "application/json",
  },
});

const CryingWine = (await response.json()) ?? [];

const matchesFoodCategory = (product, category) =>
  [product.Food_text1, product.Food_text2, product.Food_text3, product.Food_text4].some(
    (value) =>
      String(value ?? "")
        .trim()
        .toLowerCase() === category.trim().toLowerCase(),
  );

console.log(CryingWine);
---

<MainLayout title="Flasken til maden">
  <main class="mx-[var(--margin-mobile)] md:mx-[var(--margin-web)] my-40 flex flex-col gap-[var(--gapmobile-xl)] md:gap-[var(--gapweb-l)]">
    <div class="flex flex-col gap-[var(--gapmobile-s)]">
      <Heading htmlheading="h1" size="large"> Flasken til maden </Heading>

      <!-- MOBIL-->
      <!-- Mobile navigation -->
      <div class="flex gap-[var(--gapmobile-s)] carousel md:hidden">
        <Button href="#pasta" variant="secondary" form="pill">Pasta</Button>
        <Button href="#meat" variant="secondary" form="pill">Kød</Button>
        <Button href="#pizza" variant="secondary" form="pill">Pizza</Button>
        <Button href="#fish" variant="secondary" form="pill">Fisk og skaldyr</Button>
        <Button href="#tapas" variant="secondary" form="pill">Tapas</Button>
      </div>
    </div>

    <div class="md:hidden flex flex-col gap-[var(--gapmobile-xl)]">
      <section id="pasta" class="relative scroll-mt-40 self-center w-full max-w-screen-xl">
        <div>
          <Heading htmlheading="h2" size="medium">Pasta</Heading>
          <img src="/img/illustrations/food/Pasta.webp" alt="Pasta illustration" class="absolute -top-10 -right-10 lg:-top-35 md:-right-30 w-70 md:w-90 lg:w-120 -z-10 scale-[-1]" />
        </div>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(160px,175px))] lg:grid-cols-[repeat(auto-fit,minmax(250px,290px))] gap-[var(--gapmobile-m)] mt-[var(--gapmobile-l)] md:mt-[var(--gapweb-l)] justify-center md:justify-start">
          {CryingWine.filter((cryingwine) => matchesFoodCategory(cryingwine, "Pasta")).map((cryingwine) => <ProductCard product={cryingwine} quantity={1} />)}
        </div>
      </section>

      <section id="meat" class="scroll-mt-40 flex flex-col">
        <Heading htmlheading="h2" size="medium">Kød</Heading>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(160px,175px))] gap-[var(--gapmobile-m)] mt-[var(--gapmobile-l)]">
          {CryingWine.filter((c) => matchesFoodCategory(c, "Kød")).map((c) => <ProductCard product={c} quantity={1} />)}
        </div>
      </section>

      <section id="pizza" class="scroll-mt-40 flex flex-col">
        <Heading htmlheading="h2" size="medium">Pizza</Heading>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(160px,175px))] gap-[var(--gapmobile-m)] mt-[var(--gapmobile-l)]">
          {CryingWine.filter((c) => matchesFoodCategory(c, "Pizza")).map((c) => <ProductCard product={c} quantity={1} />)}
        </div>
      </section>

      <section id="fish" class="scroll-mt-40 flex flex-col">
        <Heading htmlheading="h2" size="medium">Fisk og skaldyr</Heading>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(160px,175px))] gap-[var(--gapmobile-m)] mt-[var(--gapmobile-l)]">
          {CryingWine.filter((c) => matchesFoodCategory(c, "Fisk og skaldyr")).map((c) => <ProductCard product={c} quantity={1} />)}
        </div>
      </section>

      <section id="tapas" class="scroll-mt-40 flex flex-col">
        <Heading htmlheading="h2" size="medium">Tapas</Heading>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(160px,175px))] gap-[var(--gapmobile-m)] mt-[var(--gapmobile-l)]">
          {CryingWine.filter((c) => matchesFoodCategory(c, "Tapas")).map((c) => <ProductCard product={c} quantity={1} />)}
        </div>
      </section>
    </div>

    <!-- DESKTOP -->

    <section class="md:grid grid-cols-4">
      <article class="md:grid grid-cols-[250px_auto] md:gap-[var(--gapweb-xxs)]">
        <div>
          <Heading htmlheading="h3" size="small" color="black">Kategorier</Heading>
          <ul>
            <li>
              <button type="button" data-scroll-target="pasta" class="flex items-center gap-2 font-semibold hover:cursor-pointer">Pasta</button>
            </li>
            <li>
              <button type="button" data-scroll-target="meat" class="flex items-center gap-2 font-semibold hover:cursor-pointer"> Kød </button>
            </li>
            <li>
              <button type="button" data-scroll-target="pizza" class="flex items-center gap-2 font-semibold hover:cursor-pointer"> Pizza </button>
            </li>
            <li>
              <button type="button" data-scroll-target="fish" class="flex items-center gap-2 font-semibold hover:cursor-pointer"> Fisk og skaldyr </button>
            </li>
            <li>
              <button type="button" data-scroll-target="tapas" class="flex items-center gap-2 font-semibold hover:cursor-pointer"> Tapas </button>
            </li>
          </ul>
        </div>

        <img src="/img/illustrations/CategoryLine.webp" alt="blå linje" class="" />
      </article>
      <!-- scroll sektion -->
      <article class="sticky top-0 h-screen overflow-y-hidden w-full col-span-3">
        <div id="scrollable" x-data class="h-full overflow-y-auto overflow-x-hidden overscroll-auto md:gap-[var(--gapweb-xl)] flex flex-col">
          <div id="pasta" class="relative scroll-mt-40 self-center w-full max-w-screen-xl">
            <div>
              <Heading htmlheading="h2" size="medium">Pasta</Heading>
              <img src="/img/illustrations/food/Pasta.webp" alt="Pasta illustration" class="absolute -top-10 -right-10 lg:-top-35 md:-right-30 w-70 md:w-90 lg:w-120 -z-10 scale-[-1]" />
            </div>
            <div class="grid grid-cols-[repeat(auto-fit,minmax(160px,175px))] lg:grid-cols-[repeat(auto-fit,minmax(250px,290px))] gap-[var(--gapmobile-m)] mt-[var(--gapmobile-l)] md:mt-[var(--gapweb-l)] justify-center md:justify-start">
              {CryingWine.filter((cryingwine) => matchesFoodCategory(cryingwine, "Pasta")).map((cryingwine) => <ProductCard product={cryingwine} quantity={1} />)}
            </div>
          </div>

          <div id="meat" class="relative scroll-mt-40 self-center w-full max-w-screen-xl">
            <div>
              <Heading htmlheading="h2" size="medium">Kød</Heading>
              <img src="/img/illustrations/food/Meat.webp" alt="Kød illustration" class="absolute -top-20 -right-15 lg:-top-35 md:-right-35 w-70 md:w-90 lg:w-120 -z-10 -rotate-17" />
            </div>

            <div class="grid grid-cols-[repeat(auto-fit,minmax(160px,175px))] lg:grid-cols-[repeat(auto-fit,minmax(250px,290px))] gap-[var(--gapmobile-m)] mt-[var(--gapmobile-l)] md:mt-[var(--gapweb-l)] justify-center md:justify-start">
              {CryingWine.filter((cryingwine) => matchesFoodCategory(cryingwine, "Kød")).map((cryingwine) => <ProductCard product={cryingwine} quantity={1} />)}
            </div>
          </div>

          <div id="pizza" class="relative scroll-mt-40 self-center w-full max-w-screen-xl">
            <div>
              <Heading htmlheading="h2" size="medium">Pizza</Heading>
              <img src="/img/illustrations/food/Pizza.webp" alt="Pizza illustration" class="absolute -top-10 -right-17 lg:-top-25 md:-right-30 w-70 md:w-90 lg:w-120 -z-10 rotate-12" />
            </div>

            <div class="grid grid-cols-[repeat(auto-fit,minmax(160px,175px))] lg:grid-cols-[repeat(auto-fit,minmax(250px,290px))] gap-[var(--gapmobile-m)] mt-[var(--gapmobile-l)] md:mt-[var(--gapweb-l)] justify-center md:justify-start">
              {CryingWine.filter((cryingwine) => matchesFoodCategory(cryingwine, "Pizza")).map((cryingwine) => <ProductCard product={cryingwine} quantity={1} />)}
            </div>
          </div>

          <div id="fish" class="relative scroll-mt-40 self-center w-full max-w-screen-xl">
            <div>
              <Heading htmlheading="h2" size="medium">Fisk og skaldyr</Heading>
              <img src="/img/illustrations/food/Fish.webp" alt="Fisk og skaldyr illustration" class="absolute -top-15 -right-25 lg:-top-30 md:-right-30 w-70 md:w-90 lg:w-120 -z-10 rotate-20" />
            </div>

            <div class="grid grid-cols-[repeat(auto-fit,minmax(160px,175px))] lg:grid-cols-[repeat(auto-fit,minmax(250px,290px))] gap-[var(--gapmobile-m)] mt-[var(--gapmobile-l)] md:mt-[var(--gapweb-l)] justify-center md:justify-start">
              {CryingWine.filter((cryingwine) => matchesFoodCategory(cryingwine, "Fisk og Skaldyr")).map((cryingwine) => <ProductCard product={cryingwine} quantity={1} />)}
            </div>
          </div>

          <div id="tapas" class="relative scroll-mt-40 self-center w-full max-w-screen-xl">
            <div>
              <Heading htmlheading="h2" size="medium">Tapas</Heading>
              <img src="/img/illustrations/food/Tapas.webp" alt="Tapas illustration" class="absolute -top-5 -right-20 lg:-top-15 md:-right-40 w-70 md:w-90 lg:w-120 -z-10 rotate-20" />
            </div>

            <div class="grid grid-cols-[repeat(auto-fit,minmax(160px,175px))] lg:grid-cols-[repeat(auto-fit,minmax(250px,290px))] gap-[var(--gapmobile-m)] mt-[var(--gapmobile-l)] md:mt-[var(--gapweb-l)] justify-center md:justify-start">
              {CryingWine.filter((cryingwine) => matchesFoodCategory(cryingwine, "Tapas")).map((cryingwine) => <ProductCard product={cryingwine} quantity={1} />)}
            </div>
          </div>
        </div>
      </article>
    </section>
    <ScrollToTop />
    <TasteBox />
  </main>

  <script>
    (function () {
      const container = document.getElementById("scrollable");
      if (!container) return;

      const buttons = Array.from(document.querySelectorAll("[data-scroll-target]"));
      const btnMap = new Map(buttons.map((b) => [b.getAttribute("data-scroll-target"), b]));

      function clearActive() {
        buttons.forEach((b) => {
          b.classList.remove("font-bold", "text-[var(--color-accent)]");
          b.classList.add("font-semibold");
          b.setAttribute("aria-pressed", "false");
        });
      }

      function setActiveBtn(btn) {
        clearActive();
        if (btn) {
          btn.classList.add("font-bold", "text-[var(--color-accent)]");
          btn.classList.remove("font-semibold");
          btn.setAttribute("aria-pressed", "true");
        }
      }

      // initialiser pasta som aktiv
      const initBtn = btnMap.get("pasta") || buttons[0];
      setActiveBtn(initBtn);

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.getAttribute("data-scroll-target");
          const target = document.getElementById(id);
          if (!target) return;
          const top = target.getBoundingClientRect().top - container.getBoundingClientRect().top + container.scrollTop;
          container.scrollTo({ top, behavior: "smooth" });
          setActiveBtn(btn);
        });
      });

      // Kun desktop: kør heading-observer kun på md+ viewports
      const mql = window.matchMedia("(min-width: 768px)");
      let observer = null;

      const createObserver = () => {
        if (observer) return;
        observer = new IntersectionObserver(
          (entries) => {
            const visibleEntries = entries.filter((e) => e.isIntersecting);
            if (visibleEntries.length > 0) {
              const topEntry = visibleEntries.sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
              const parentDiv = topEntry.target.closest("[id]");
              const id = parentDiv ? parentDiv.id : null;
              const btn = id ? btnMap.get(id) : null;
              if (btn) setActiveBtn(btn);
            } else {
              clearActive();
            }
          },
          { root: container, rootMargin: "0px", threshold: [0, 0.01, 0.25, 0.5, 0.75, 1] },
        );

        document.querySelectorAll("[id] h2").forEach((heading) => {
          observer.observe(heading);
        });
      };

      const destroyObserver = () => {
        if (!observer) return;
        observer.disconnect();
        observer = null;
      };

      const handleMqlChange = (e) => {
        if (e.matches) createObserver();
        else destroyObserver();
      };

      if (mql.matches) createObserver();
      if (mql.addEventListener) mql.addEventListener("change", handleMqlChange);
      else mql.addListener(handleMqlChange);
    })();
  </script>
</MainLayout>
