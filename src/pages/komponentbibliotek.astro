---
import MainLayout from "../layouts/MainLayout.astro";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import Link from "../components/Link.astro";
import Button from "../components/Button.astro";
import ContactInfo from "../components/ContactInfo.astro";
import TasteBox from "../components/TasteBox.astro";
import CardButton from "../components/CardButton.astro";
import Favorites from "../components/Favorites.astro";
import ProductCard from "../components/ProductCard.astro";

const SUPABASE_URL = "https://lbkrfecnofyqzkuhuins.supabase.co";

const SUPABASE_KEY = "sb_publishable_y5b_SwFaDlD8jvcpEA-GiQ_nP-3VCkg";

const response = await fetch(`${SUPABASE_URL}/rest/v1/CryingWine?select=*`, {
  method: "GET",
  headers: {
    apikey: SUPABASE_KEY,
    Authorization: `Bearer ${SUPABASE_KEY}`,
    "Content-Type": "application/json",
  },
});

const CryingWine = (await response.json()) ?? [];

const firstProduct = CryingWine[0] ?? {
  id: "0",
  Category: "DEMO",
  img1: "/img/illustrations/VectorLine.png",
  img2: "/img/illustrations/VectorLine.png",
  Badge1: "",
  Badge2: "",
  Badge3: "",
  Productname: "Demo Produkt",
  Price: "0",
};
---

<MainLayout title="Komponentbibliotek">
  <main class="container mx-auto p-4 gap-[var(--gapmobile-xl)] md:gap-[var(--gapweb-xl)] my-40 flex flex-col">
    <Heading htmlheading="h1" size="large">Komponentbibliotek</Heading>
    <Text stylingclasses="italic">Her kan du finde alle de komponenter, der er brugt i dette projekt.</Text>
    <hr class="my-4" />
    <!-- start på typografi -->
    <section class="my-15">
      <div class="my-5">
        <Heading htmlheading="h2" size="medium"> Text komponenter - alle teksttyper </Heading>
      </div>

      <!-- Headline -->
      <div class="my-10 flex flex-col gap-3">
        <Text teksttype="headline" weight="light" color="body"> Headline - Light - Body </Text>

        <Text teksttype="headline" weight="regular" color="body"> Headline - Regular - Body </Text>

        <Text teksttype="headline" weight="bold" color="body"> Headline - Bold - Body </Text>

        <Text teksttype="headline" weight="bold" color="primary"> Headline - Bold - Primary </Text>

        <Text teksttype="headline" weight="bold" color="secondary"> Headline - Bold - Secondary </Text>

        <Text teksttype="headline" weight="bold" color="negative" stylingclasses="bg-primary p-2 rounded-2xl block"> Headline - Bold - Negative </Text>
      </div>

      <!-- Body -->
      <div class="my-10 flex flex-col gap-3">
        <Text teksttype="body" weight="light" color="body"> Body - Light - Body </Text>

        <Text teksttype="body" weight="regular" color="body"> Body - Regular - Body </Text>

        <Text teksttype="body" weight="bold" color="body"> Body - Bold - Body </Text>

        <Text teksttype="body" weight="bold" color="primary"> Body - Bold - Primary </Text>

        <Text teksttype="body" weight="bold" color="secondary"> Body - Bold - Secondary </Text>

        <Text teksttype="body" weight="bold" color="negative" stylingclasses="bg-primary p-2 rounded-2xl block"> Body - Bold - Negative </Text>
      </div>

      <!-- Subtitle -->
      <div class="my-10 flex flex-col gap-3">
        <Text teksttype="subtitle" weight="light" color="body"> Subtitle - Light - Body </Text>

        <Text teksttype="subtitle" weight="regular" color="body"> Subtitle - Regular - Body </Text>

        <Text teksttype="subtitle" weight="bold" color="body"> Subtitle - Bold - Body </Text>

        <Text teksttype="subtitle" weight="bold" color="primary"> Subtitle - Bold - Primary </Text>

        <Text teksttype="subtitle" weight="bold" color="secondary"> Subtitle - Bold - Secondary </Text>

        <Text teksttype="subtitle" weight="bold" color="negative" stylingclasses="bg-primary p-2 rounded-2xl block"> Subtitle - Bold - Negative </Text>
      </div>

      <!-- Caption -->
      <div class="my-10 flex flex-col gap-3">
        <Text teksttype="caption" weight="caption" color="body"> Caption - Regular - Body </Text>

        <Text teksttype="caption" weight='caption"' color="primary"> Caption - Regular - Primary </Text>

        <Text teksttype="caption" weight='caption"' color="secondary"> Caption - Regular - Secondary </Text>

        <Text teksttype="caption" weight='caption"' color="negative" stylingclasses="bg-primary px-2 rounded-2xl block"> Caption - Regular - Negative </Text>
      </div>

      <!-- Footnote -->
      <div class="my-10 flex flex-col gap-3">
        <Text teksttype="footnote" weight="light" color="body"> Footnote - Light - Body </Text>

        <Text teksttype="footnote" weight="regular" color="body"> Footnote - Regular - Body </Text>

        <Text teksttype="footnote" weight="bold" color="body"> Footnote - Bold - Body </Text>

        <Text teksttype="footnote" weight="bold" color="primary"> Footnote - Bold - Primary </Text>

        <Text teksttype="footnote" weight="bold" color="secondary"> Footnote - Bold - Secondary </Text>

        <Text teksttype="footnote" weight="bold" color="negative" stylingclasses="bg-primary p-2 rounded-2xl block"> Footnote - Bold - Negative </Text>
      </div>

      <!-- Label -->
      <div class="my-10 flex flex-col gap-3">
        <Text teksttype="label" weight="light" color="body"> Label - Light - Body </Text>

        <Text teksttype="label" weight="regular" color="body"> Label - Regular - Body </Text>

        <Text teksttype="label" weight="bold" color="body"> Label - Bold - Body </Text>

        <Text teksttype="label" weight="bold" color="primary"> Label - Bold - Primary </Text>

        <Text teksttype="label" weight="bold" color="secondary"> Label - Bold - Secondary </Text>

        <Text teksttype="label" weight="bold" color="negative" stylingclasses="bg-primary p-2 rounded-2xl block"> Label - Bold - Negative </Text>
      </div>
    </section><!-- slut på typografi -->

    <hr class="my-4" />
    <!-- Link komponent instanser -->
    <section>
      <Heading htmlheading="h2" size="medium">Links</Heading>
      <Text teksttype="brødtekst"><Link href="#">Default link: </Link>Default linket er en del af en tekst, og burde gerne fungere som et <Link href="#">link</Link> i en paragraf.</Text>
      <Text><Link href="#" variant="primary">Link variant: primary</Link></Text>
      <Text><Link href="#" variant="secondary">Link variant: secondary</Link></Text>
    </section>
    <!-- Slut på Link komponent instanser -->
    <hr class="my-4" />
    <!-- Buttons komponent instanser -->
    <section>
      <Heading htmlheading="h2" size="medium">Buttons</Heading>
      <Text><Button>Default knap</Button></Text>
      <Text><Button variant="secondary"> knap secondary</Button></Text>
      <Text><Button variant="primary" form="pill">Pill knap primary</Button></Text>
      <Text><Button variant="secondary" form="pill">Pill knap secondary</Button></Text>
    </section>
    <!-- Slut på Buttons komponent instanser -->
    <hr class="my-4" />
    <!-- smagskasse komponent -->
    <section>
      <Heading htmlheading="h2" size="medium">Smagskasser</Heading>
      <TasteBox />
    </section>
    <hr class="my-4" />
    <!-- kontakt info komponent -->
    <section>
      <Heading htmlheading="h2" size="medium">Kontaktinfo</Heading>
      <ContactInfo tekst="kontaktinformationer" label="overskrift" />
    </section>
    <hr class="my-4" />
    <!-- knap på card komponent -->
    <section>
      <Heading htmlheading="h2" size="medium">Knap på Card</Heading>
      <CardButton variant="primary"> klik her </CardButton>
    </section>
    <hr class="my-4" />
    <!-- favorit komponent -->
    <section>
      <Heading htmlheading="h2" size="medium">Favorit komponent</Heading>
      <Favorites />
    </section>
    <hr class="my-4" />
    <!-- Produktkort komponent -->
    <section>
      <Heading htmlheading="h2" size="medium">Produktkort</Heading>
      <div class="grid grid-cols-[repeat(auto-fit,minmax(160px,175px))] lg:grid-cols-[repeat(auto-fit,minmax(250px,290px))] gap-[var(--gapmobile-m)] mt-[var(--gapmobile-l)] md:mt-[var(--gapweb-l)] justify-center md:justify-start">
        <ProductCard product={firstProduct} quantity={1} />
      </div>
    </section>
  </main></MainLayout
>
